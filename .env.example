## Required
TWELVE_DATA_KEY=your_twelvedata_key
BOT_RUN_SECRET=change_this_to_a_long_random_string

## Optional (Telegram notifications)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
MY_CHAT_ID=your_chat_id

## Strategy config (optional)
BOT_UNIVERSE=AAPL,MSFT,NVDA,TSLA
BOT_INTERVAL=1h
BOT_OUTPUTSIZE=300
BOT_LOOKBACK_BARS=48
BOT_CRON=0 * * * *
BOT_BUY_THRESHOLD_PCT=2
BOT_SELL_THRESHOLD_PCT=0.5
BOT_POSITION_USD=100
BOT_MAX_POSITIONS=3
BOT_MODE=paper

## Used by dashboard in prod (optional)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

